{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"scopeName": "csharp.modern.injection",
	"injectionSelector": "source.cs -comment -string",
	"patterns":
	[
		{ "include": "#namespace-declaration-path" },
		{ "include": "#using-directive-namespace-path" },
		{ "include": "#scoped-modifier" },
		{ "include": "#checked-conversion-operator-declaration" },
		{ "include": "#checked-operator-declaration" }
	],
	"repository":
	{
		"namespace-declaration-path":
		{
			"match": "(?x)\n(?<!\\.)\n\\b(namespace)\\b\\s+\n(@?[_[:alpha:]][_[:alnum:]]*(?:\\s*\\.\\s*@?[_[:alpha:]][_[:alnum:]]*)*)\n\\s*\n(?=[{;])",
			"captures":
			{
				"1": { "name": "storage.type.namespace.cs" },
				"2":
				{
					"patterns":
					[
						{ "match": "@?[_[:alpha:]][_[:alnum:]]*", "name": "entity.name.type.namespace.cs" },
						{ "match": "\\.", "name": "punctuation.accessor.namespace.cs" }
					]
				}
			}
		},
		"using-directive-namespace-path":
		{
			"match": "(?x)\n(?<!\\.)\n(?:\\b(global)\\s+)?\n\\b(using)\\b\\s*\n(?:\\b(static)\\b\\s*)?\n(?:\\b(unsafe)\\b\\s*)?\n(?!var\\b|\\()\n(@?[_[:alpha:]][_[:alnum:]]*(?:\\s*\\.\\s*@?[_[:alpha:]][_[:alnum:]]*)*)\n\\s*\n(?=;)",
			"captures":
			{
				"1": { "name": "keyword.other.directive.global.cs" },
				"2": { "name": "keyword.other.directive.using.cs" },
				"3": { "name": "keyword.other.directive.static.cs" },
				"4": { "name": "storage.modifier.unsafe.cs" },
				"5":
				{
					"patterns":
					[
						{ "match": "@?[_[:alpha:]][_[:alnum:]]*", "name": "entity.name.type.namespace.cs" },
						{ "match": "\\.", "name": "punctuation.accessor.namespace.cs" }
					]
				}
			}
		},
		"scoped-modifier":
		{
			"match": "(?<!\\.)\\b(scoped)\\b(?=\\s+(?:ref\\b|in\\b|out\\b|readonly\\b|@?[_[:alpha:]]))",
			"captures":
			{
				"1": { "name": "storage.modifier.scoped.cs" }
			}
		},
		"checked-conversion-operator-declaration":
		{
			"begin": "(?x)\n(?<explicit_or_implicit_keyword>\\b(?:explicit|implicit)\\b)\n\\s+\n(?<operator_keyword>\\boperator\\b)\n\\s+\n(?<checked_keyword>\\bchecked\\b)\n\\s+\n(?<type_name>\n  (?:ref\\s+(?:readonly\\s+)?)?\n  @?[_[:alpha:]][_[:alnum:]]*\n  (?:\\s*<[^<>]*(?:<[^<>]*>[^<>]*)*>)?\n  (?:\\s*\\?)?\n  (?:\\s*\\[\\s*,*\\s*\\]\\s*\\??)*\n  (?:\\s*\\.\\s*@?[_[:alpha:]][_[:alnum:]]*(?:\\s*<[^<>]*>)?)*\n)\n\\s*\n(?=\\()",
			"beginCaptures":
			{
				"1":
				{
					"patterns":
					[
						{ "match": "\\b(explicit)\\b", "captures": { "1": { "name": "storage.modifier.explicit.cs" } } },
						{ "match": "\\b(implicit)\\b", "captures": { "1": { "name": "storage.modifier.implicit.cs" } } }
					]
				},
				"2": { "name": "storage.type.operator.cs" },
				"3": { "name": "storage.modifier.checked.cs" },
				"4": { "patterns": [ { "include": "source.cs#type" } ] }
			},
			"end": "(?<=\\})|(?=;)",
			"patterns":
			[
				{ "include": "source.cs#comment" },
				{ "include": "source.cs#parenthesized-parameter-list" },
				{ "include": "source.cs#expression-body" },
				{ "include": "source.cs#block" }
			]
		},
		"checked-operator-declaration":
		{
			"begin": "(?x)\n(?<return_type>\n  (?:ref\\s+(?:readonly\\s+)?)?\n  @?[_[:alpha:]][_[:alnum:]]*\n  (?:\\s*<[^<>]*(?:<[^<>]*>[^<>]*)*>)?\n  (?:\\s*\\?)?\n  (?:\\s*\\[\\s*,*\\s*\\]\\s*\\??)*\n)\n\\s+\n(?<operator_keyword>\\boperator\\b)\n\\s+\n(?<checked_keyword>\\bchecked\\b)\n\\s+\n(?<operator_symbol>[+\\-*/%&|\\^!=~<>]+|true|false)\n\\s*\n(?=\\()",
			"beginCaptures":
			{
				"1": { "patterns": [ { "include": "source.cs#type" } ] },
				"2": { "name": "storage.type.operator.cs" },
				"3": { "name": "storage.modifier.checked.cs" },
				"4": { "name": "entity.name.function.cs" }
			},
			"end": "(?<=\\})|(?=;)",
			"patterns":
			[
				{ "include": "source.cs#comment" },
				{ "include": "source.cs#parenthesized-parameter-list" },
				{ "include": "source.cs#expression-body" },
				{ "include": "source.cs#block" }
			]
		}
	}
}
